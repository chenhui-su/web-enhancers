{
  "name": "web-enhancers",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsx scripts/build-all.ts",
    "build:all": "tsx scripts/build-all.ts",
    "build:gemini": "tsx scripts/build.ts gemini-ui-enhancer",
    "build:page": "tsx scripts/build.ts page-enhancer",
    "dev:gemini": "tsx scripts/build.ts gemini-ui-enhancer --watch",
    "dev:page": "tsx scripts/build.ts page-enhancer --watch",
    "validate:release": "tsx scripts/validate-release.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build:all"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.7",
    "esbuild": "^0.24.2",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.0.2"
  }
}
